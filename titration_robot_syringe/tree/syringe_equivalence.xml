<?xml version="1.0"?>
<root main_tree_to_execute="syringe_equivalence">
    <!-- ////////// -->
    <BehaviorTree ID="syringe_equivalence">
        <Sequence>
            <AlwaysSuccess/>
            <ReactiveSequence>
                <Inverter>
                    <Condition ID="CheckPhByRange" editable="" ph_max="14.00" ph_min="10.01"/>
                </Inverter>
                <RetryUntilSuccessful num_attempts="-1">
                    <Sequence>
                        <RetryUntilSuccessful num_attempts="-1">
                            <Condition ID="IsPhStable" delta_max="0.02" delta_min="0.00" editable="" window_sec="30"/>
                        </RetryUntilSuccessful>
                        <IfThenElse>
                            <Condition ID="CheckDphDv" criteria_max="0.0005" criteria_min="0.0000" editable=""/>
                            <Sequence>
                                <Action ID="SetDispenseVolume" editable="" volume="2000"/>
                                <SetBlackboard output_key="delay" value="1500"/>
                            </Sequence>
                            <IfThenElse>
                                <Condition ID="CheckDphDv" criteria_max="0.0020" criteria_min="0.0005" editable=""/>
                                <Sequence>
                                    <Action ID="SetDispenseVolume" editable="" volume="2000"/>
                                    <SetBlackboard output_key="delay" value="1500"/>
                                </Sequence>
                                <Sequence>
                                    <Action ID="SetDispenseVolume" editable="" volume="2000"/>
                                    <SetBlackboard output_key="delay" value="1500"/>
                                </Sequence>
                            </IfThenElse>
                        </IfThenElse>
                        <Delay delay_msec="{delay}">
                            <Action ID="Dispense" editable=""/>
                        </Delay>
                        <Delay delay_msec="10000">
                            <AlwaysSuccess/>
                        </Delay>
                    </Sequence>
                </RetryUntilSuccessful>
            </ReactiveSequence>
        </Sequence>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Condition ID="CheckDphDv">
            <input_port name="criteria_max"/>
            <input_port name="criteria_min"/>
            <inout_port name="editable"/>
        </Condition>
        <Condition ID="CheckPhByRange">
            <inout_port name="editable"/>
            <input_port name="ph_max"/>
            <input_port name="ph_min"/>
        </Condition>
        <Action ID="Dispense">
            <inout_port name="editable"/>
        </Action>
        <Condition ID="IsPhStable">
            <input_port name="delta_max"/>
            <input_port name="delta_min"/>
            <inout_port name="editable"/>
            <input_port name="window_sec"/>
        </Condition>
        <Action ID="SetDispenseVolume">
            <inout_port name="editable"/>
            <input_port name="volume"/>
        </Action>
    </TreeNodesModel>
    <!-- ////////// -->
</root>
